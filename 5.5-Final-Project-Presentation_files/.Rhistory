import pandas as pd
# 1. Use the dataframe showing in your sample
plot_df = py_data.copy()
# 2. Convert plotting variables to numeric to ensure a proper scale
plot_df['WKHRS'] = pd.to_numeric(plot_df['WKHRS'], errors='coerce')
plot_df['ACT_CHCARE'] = pd.to_numeric(plot_df['ACT_CHCARE'], errors='coerce')
# 3. Clean up missing values
# We use 'sex_label' since 'female' was all zeros in your sample
plot_df = plot_df.dropna(subset=['sex_label', 'WKHRS', 'ACT_CHCARE'])
# 4. Create the Plot
plt.figure(figsize=(10, 6))
sns.lineplot(
data=plot_df,
x='WKHRS',
y='ACT_CHCARE',
hue='sex_label',   # Use the label column directly!
marker='o',
palette={'Female': 'tab:pink', 'Male': 'tab:blue'},
errorbar=None      # Set to ('ci', 95) if you want the shaded confidence interval
)
