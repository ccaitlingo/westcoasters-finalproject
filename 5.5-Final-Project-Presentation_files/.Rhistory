plt.title('Relationship between Work Hours and Childcare Time', fontsize=14, pad=15)
plt.xlabel('Weekly Work Hours (WKHRS)', fontsize=12)
plt.ylabel('Daily Childcare (ACT_CHCARE)', fontsize=12)
plt.legend(title='Gender')
plt.grid(True, linestyle='--', alpha=0.5)
# Limit X-axis to standard working hours for better visibility
plt.xlim(0, 80)
plt.tight_layout()
plt.show()
