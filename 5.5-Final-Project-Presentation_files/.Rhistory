library(kableExtra)
loadings <- as.data.frame(pca_res$rotation[, 1:5])
loadings$variable <- rownames(loadings)
highlight <- apply(abs(loadings[, 1:5]), 2, function(col) {
rank(-col) <= 3
})
for (j in 1:5) {
loadings[[j]] <- ifelse(
highlight[, j],
cell_spec(round(loadings[[j]], 3), bold = TRUE),
round(loadings[[j]], 3)
)
}
kable(loadings, escape = FALSE) %>%
kable_styling(full_width = FALSE)
