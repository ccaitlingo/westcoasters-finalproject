library(kableExtra)
loadings_df <- as.data.frame(pca_res$rotation[, 1:5]) %>%
mutate(variable = rownames(.)) %>%
pivot_longer(-variable, names_to = "PC", values_to = "loading") %>%
group_by(PC) %>%
mutate(top3 = rank(-abs(loading)) <= 3) %>%
ungroup()
loadings_wide <- loadings_df %>%
mutate(loading = ifelse(top3,
cell_spec(round(loading, 3), bold = TRUE, background = "lightyellow"),
round(loading, 3))) %>%
select(-top3) %>%
pivot_wider(names_from = PC, values_from = loading)
kable(loadings_wide, escape = FALSE) %>%
kable_styling(full_width = FALSE)
