pct
# Group clusters 2+3 (representing the top right of graph) and 1+4+5
grp <- ifelse(pca_scores$cluster %in% c(2,3), "C2+3", "C1+4+5")
pct_grp <- round(prop.table(table(grp, pca_scores$binary_var), 1) * 100, 1)
pct_grp
pca_scores <- as.data.frame(pca_res$x[, 1:4])
pca_scores
# Hierarchical clustering on PCA space
dist_mat <- dist(pca_scores)
hc <- hclust(dist_mat, method = "ward.D2")
# Cut into clusters
k <- 5
clusters <- cutree(hc, k = k)
# Attach cluster + sex
pca_scores$cluster <- factor(clusters)
pca_scores$binary_var <- df_sample$binary_var
pca_res$rotation[, 1:4]
pca_res$rotation[, 1:5]
pca_res$rotation[, 1:5]
loadings <- pca_res$rotation[, 1:5]
# Get top 3 (by absolute value) per column
highlight <- apply(abs(loadings), 2, function(col) {
rank(-col) <= 3
})
# Create formatted matrix
formatted <- matrix("", nrow = nrow(loadings), ncol = ncol(loadings))
rownames(formatted) <- rownames(loadings)
colnames(formatted) <- colnames(loadings)
for (i in 1:nrow(loadings)) {
for (j in 1:ncol(loadings)) {
val <- round(loadings[i, j], 3)
if (highlight[i, j]) {
formatted[i, j] <- paste0("**", val, "**")  # bold
} else {
formatted[i, j] <- as.character(val)
}
}
}
formatted
