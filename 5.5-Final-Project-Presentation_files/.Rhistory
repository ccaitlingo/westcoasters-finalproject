codebook <- tibble::tribble(
~Variable, ~Description, ~Type,
"WAGELM", "Monthly employment income", "Numerical",
"ACT_PAID", "Daily time spent on paid work", "Numerical",
"ACT_UNPAID", "Daily time spent on unpaid domestic work (including childcare)", "Numerical",
"SEX", "Individual's sex (female=1, male=0)", "Binary"
)
codebook %>%
gt() %>%
tab_header(title = "Codebook") %>%
tab_options(table.font.size = px(10)) %>%
cols_width(
Variable ~ px(120),
Description ~ px(300),
Type ~ px(120)
) %>%
tab_style(
style = cell_borders(
sides = "bottom",
color = "grey",
weight = px(1)
),
locations = cells_body()
)
